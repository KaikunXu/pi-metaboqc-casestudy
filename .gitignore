# ==============================================================================
# Gitignore for pi-metaboqc-casestudy
# ==============================================================================

# ------------------------------------------------------------------------------
# Custom Project Rules
# ------------------------------------------------------------------------------
# Ignore all files and scripts starting with '#' 
# (e.g., discarded data, experimental or temporary scripts)
\#*

# ------------------------------------------------------------------------------
# Python Runtime & Compiled Files
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# Virtual Environments & Package Managers
# ------------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
# VS Code specific
.vscode/
*.code-workspace
.history/

# PyCharm / IntelliJ
.idea/

# General editor artifacts
*.swp
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Jupyter Notebooks & Data Science Tools
# ------------------------------------------------------------------------------
.ipynb_checkpoints
*/.ipynb_checkpoints/
.Rhistory
.RData
.Ruserdata